# Browser-side API base URL.
# Use /api with Nginx reverse proxy in most deployments.
VITE_API_BASE_URL=/api

# Local Vite dev server settings.
VITE_DEV_PORT=3000
VITE_DEV_API_ORIGIN=http://localhost:5681

# Container runtime variables are injected by the platform, not by Vite.
# APP_API_BASE_URL=/api
# BACKEND_UPSTREAM=https://your-backend-domain
